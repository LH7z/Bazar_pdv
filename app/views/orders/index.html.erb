<h1 class="text-3xl font-bold mb-6 text-center text-gray-800 mt-6">Meus Pedidos</h1>

<% if @orders.empty? %>
  <p class="text-gray-500">Nenhum pedido encontrado.</p>
<% else %>
  <div style="margin: 0 20px;">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <% @orders.each do |order| %>
        <div class="bg-white rounded-lg shadow p-4 hover:shadow-lg transition">
          <div class="flex justify-between items-start">
            <div>
              <h2 class="font-semibold text-lg">Pedido #<%= order.id %></h2>
              <p class="text-gray-500 text-sm">Data: <%= order.created_at.strftime("%d/%m/%Y") %></p>
              <p class="text-gray-500 text-sm">Itens: <%= order.order_items.sum(&:quantity) %></p>
              <% order.order_items.each do |item| %>
                <p class="text-gray-500 text-sm"> - <%= item.product_variant.product.name %> (Qtd: <%= item.quantity %>) Preço Total: <%= number_to_currency(item.price * item.quantity, unit: "", separator: ",", delimiter: ".") %> </p>
              <% end %>
              <p class="text-gray-500 text-sm">Status: <%= order.status %></p>
              <p class="text-gray-500 text-sm">Pagamento: <%= order.payment_method %></p>
              <p class="text-gray-500 text-sm">Total: R$ <%= number_to_currency(order.total, unit: "", separator: ",", delimiter: ".") %></p>
            </div>
            <div class="text-right">
              <span class="font-bold text-blue-600">Total: R$ <%= number_to_currency(order.total, unit: "", separator: ",", delimiter: ".") %></span>
            </div>
          </div>

          <div class="mt-4 flex justify-end">
            <%= link_to "Ver Detalhes", order_path(order), class: "bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition" %>
          </div>
        </div>
      <% end %>
    </div>
</div>
<% end %>
