<h1 class="text-3xl font-bold mb-6 text-center text-gray-800">CAIXA</h1>

<% if @cart.empty? %>
  <p class="text-gray-500 text-center text-lg">Nenhum item no caixa.</p>
<% else %>
  <div class="flex flex-col md:flex-row gap-6">
    <!-- Lista de Produtos -->
    <div class="flex-1 space-y-4">
      <% @cart.each do |variant_id, quantity| %>
        <% variant = @variants[variant_id.to_i] %>
        <div class="flex justify-between items-center border rounded-lg p-4 hover:shadow-lg transition bg-white">
          <!-- Info do Produto -->
          <div class="flex flex-col">
            <p class="font-semibold text-lg text-gray-800"><%= variant.product.name %></p>
            <p class="text-sm text-gray-500"><%= variant.size %> - <%= variant.color %></p>
          </div>

          <!-- Quantidade -->
          <div class="flex items-center gap-2">
            <%= button_to "-", remove_from_cart_path(variant.id), method: :delete,
                class: "bg-red-500 text-white w-8 h-8 rounded hover:bg-red-600 transition font-bold" %>
            <span class="text-lg font-medium w-6 text-center"><%= quantity %></span>
            <%= button_to "+", add_to_cart_path(variant.id), method: :post,
                class: "bg-green-500 text-white w-8 h-8 rounded hover:bg-green-600 transition font-bold" %>
          </div>

          <!-- Subtotal -->
          <div class="text-right font-semibold text-gray-800">
            R$ <%= '%.2f' % (variant.product.price * quantity) %>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Sidebar Total e Finalizar -->
    <div class="w-full md:w-80 bg-gray-50 p-4 rounded-lg shadow-lg flex flex-col justify-between">
      <div>
        <h2 class="text-xl font-bold mb-4 text-gray-800">Resumo da Compra</h2>
        <div class="flex justify-between text-lg font-medium mb-2">
          <span>Total:</span>
          <span>R$ <%= '%.2f' % @cart.sum { |variant_id, quantity| @variants[variant_id.to_i].product.price * quantity } %></span>
        </div>
      </div>

      <button id="open-modal"
        class="mt-4 bg-blue-600 text-white px-6 py-3 rounded hover:bg-blue-700 transition transform hover:scale-105 text-lg font-semibold">
        Finalizar Venda
      </button>
    </div>
  </div>

  <!-- Modal -->
  <div id="modal" class="fixed inset-0 bg-black/60 backdrop-blur-sm hidden z-50 flex justify-center items-center">
  <div class="bg-white w-full max-w-md rounded-2xl shadow-2xl p-6 relative animate-fadeIn">

    <div class="flex justify-between items-center mb-5">
      <h2 class="text-2xl font-bold text-gray-800">Novo Pedido</h2>
      <button id="close-x"
        class="text-gray-400 hover:text-red-500 text-2xl font-bold transition">&times;</button>
    </div>

    <div class="bg-gray-100 rounded-lg p-4 mb-5 text-center">
      <p class="text-sm text-gray-500">Valor Total</p>
      <p class="text-2xl font-bold text-green-600">
        R$ <%= '%.2f' % @cart.sum { |variant_id, quantity| @variants[variant_id.to_i].product.price * quantity } %>
      </p>
    </div>

    <%= form_with url: orders_path, method: :post, local: true do |f| %>
      <div class="mb-4">
        <label class="block text-gray-700 mb-2 font-medium">
          Método de Pagamento
        </label>

        <%= f.select :payment_method,
          ["Cartão de Crédito", "Pix", "Boleto", "Dinheiro"], {},
          class: "w-full border border-gray-300 p-3 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 transition"
        %>
      </div>
      <div class="mb-4" id="amount-wrapper" hidden>
        <label class="block text-gray-700 mb-2 font-medium">
          Valor Pago
        </label>

        <input type="number"
          id="order_amount"
          name="order[amount]"
          placeholder="Digite o valor pago"
          class="w-full border border-gray-300 p-3 rounded-lg focus:outline-none focus:ring-2 transition"
        >
      </div>

      <div class="bg-green-50 border border-green-200 rounded-lg p-3 mb-5 flex justify-between items-center" hidden id="change-wrapper">
        <span class="text-gray-600">Troco</span>
        <span class="text-lg font-bold text-green-700">
          R$ <span id="change">0.00</span>
        </span>
      </div>

      <div class="flex justify-end gap-3">
        <button type="button" id="close-modal"
          class="px-4 py-2 rounded-lg bg-gray-200 hover:bg-gray-300 transition font-medium">
          Cancelar
        </button>

        <%= f.submit "Finalizar Pedido",
          class: "px-5 py-2 rounded-lg bg-green-600 text-white hover:bg-green-700 transition font-semibold shadow-md",
          id: "submit-order"
        %>
      </div>

    <% end %>
  </div>
</div>

  <!-- JS Modal -->
  <script>
    const setupModal = () => {
      const modal = document.getElementById('modal');
      const openBtn = document.getElementById('open-modal');
      const closeBtn = document.getElementById('close-modal');
      const closeX = document.getElementById('close-x');
      const paymentSelect = document.getElementById('payment_method');
      const amountInput = document.getElementById('order_amount');
      const submit = document.getElementById('submit-order');
      const changeWrapper = document.getElementById('change-wrapper');
      const amountWrapper = document.getElementById('amount-wrapper');

      if (!modal || !openBtn || !closeBtn || !closeX) return;

      paymentSelect.addEventListener('change', () => {
        if (paymentSelect.value === "Dinheiro") {
          amountInput.style.display = 'block';
          changeWrapper.hidden = false;
          amountWrapper.hidden = false;
        } else {
          amountInput.style.display = 'none';
          changeWrapper.hidden = true;
          amountWrapper.hidden = true;
        }
      });

      amountInput.addEventListener('input', () => {
        const total = <%= @cart.sum { |variant_id, quantity| @variants[variant_id.to_i].product.price * quantity } %>;
        const paidAmount = parseFloat(amountInput.value.replace(',','.'));
        if (paidAmount >= total) {
          changeWrapper.hidden = false;
          amountInput.classList.remove('border-red-500');
          amountInput.classList.add('border-green-500');
          submit.disabled = false;
          submit.classList.remove('opacity-50', 'cursor-not-allowed');
          const change = paidAmount - total;
          document.getElementById('change').textContent = change.toFixed(2).replace('.', ',');
        } else {
          changeWrapper.hidden = true;
          amountInput.classList.remove('border-green-500');
          amountInput.classList.add('border-red-500');
          submit.disabled = true;
          submit.classList.add('opacity-50', 'cursor-not-allowed');
        }
      });

      const openModal = () => {modal.style.display = 'flex'; };
      const closeModal = () => { modal.style.display = 'none'; };

      openBtn.addEventListener('click', openModal);
      closeBtn.addEventListener('click', closeModal);
      closeX.addEventListener('click', closeModal);

      modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
    };

    document.addEventListener('DOMContentLoaded', setupModal);
    document.addEventListener('turbo:load', setupModal);
  </script>
<% end %>
