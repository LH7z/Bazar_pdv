<div class="max-w-6xl mx-auto p-6">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-10">

    <!-- Imagens -->
    <div>
      <% if @product.image.attached? %>
        <%= image_tag @product.image, class: "w-full h-96 object-cover rounded-xl mb-4" %>
      <% else %>
        <div class="w-full h-96 bg-gray-200 flex items-center justify-center rounded-xl">
          <span class="text-gray-500">Sem imagem</span>
        </div>
      <% end %>
    </div>

    <!-- Info -->
    <div>
      <h1 class="text-3xl font-bold mb-2"><%= @product.name %></h1>

      <p class="text-gray-500 mb-4"><%= @product.category %></p>

      <p class="text-2xl text-green-600 font-bold mb-6">
        <%= number_to_currency(@product.price, unit: "R$ ", separator: ",", delimiter: ".") %>
      </p>

      <p class="text-gray-700 mb-6">
        <%= @product.description %>
      </p>

      <!-- Variações -->
      <div class="mb-6">
        <h2 class="font-semibold mb-2">Variações</h2>

        <div class="space-y-2">
          <% @product.product_variants.each do |variant| %>
            <div class="border p-3 rounded flex justify-between">
              <span>
                <strong><%= variant.size %></strong> /
                <%= variant.color %>
              </span>

              <span class="text-sm text-gray-500">
                Estoque: <%= variant.stock %>
              </span>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Botões -->
      <div class="flex gap-3">
        <%= link_to "Editar", edit_product_path(@product),
          class: "bg-yellow-500 text-white px-4 py-2 rounded hover:bg-yellow-600" %>

        <%= link_to "Excluir", product_path(@product),
          data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" },
          class: "bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700" %>
      </div>
    </div>

  </div>
</div>
